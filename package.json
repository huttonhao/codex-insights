{
  "name": "codex-insights",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Codex plugin, MCP server, and CLI for localized Codex session insights.",
  "bin": {
    "codex-insights": "./dist/packages/cli/src/main.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
